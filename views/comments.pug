extends layout

block content
  section.page-head
    .container
      span.eyebrow We'd love to hear from you
      h1 Customer Comments
      p.muted Leave a note about your visit — your message posts to the wall below.

  section.section
    .container.comments-layout
      .comment-form-card
        h2 Leave a comment
        if error
          p.alert.alert-error= error
        if success
          p.alert.alert-success Thanks! Your comment was posted.
        form.comment-form(method='POST', action='/comments/create')
          label(for='name') Name
          input#name(type='text', name='name', maxlength='60', required, placeholder='Your name')

          label(for='rating') Rating
          select#rating(name='rating')
            option(value='5') ★★★★★ (5)
            option(value='4') ★★★★ (4)
            option(value='3') ★★★ (3)
            option(value='2') ★★ (2)
            option(value='1') ★ (1)

          label(for='message') Message
          textarea#message(name='message', rows='4', maxlength='500', required, placeholder='Tell us about your visit...')

          button.btn.btn-primary(type='submit') Post comment

      .comment-wall
        h2 What folks are saying
        if !comments || comments.length === 0
          p.muted No comments yet — be the first!
        each c in comments
          article.comment
            .comment-top
              span.comment-name= c.name
              span.comment-stars(aria-label=c.rating + ' out of 5 stars')= '★'.repeat(c.rating) + '☆'.repeat(5 - c.rating)
            p.comment-msg= c.message
            if c.created_at
              time.comment-date.muted= new Date(c.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
